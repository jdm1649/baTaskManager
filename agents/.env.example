# Copy to .env and adjust.
# LM Studio exposes both an OpenAI-compatible server on /v1 and a richer
# native API on /api/v0. This project uses /api/v0 for its stats metadata
# (stop reason, tokens/second, token counts, quant, loaded context length).

LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_NATIVE_URL=http://127.0.0.1:1234/api/v0
LM_STUDIO_API_KEY=lm-studio

# Model id as it appears in LM Studio's loaded-model list.
BA_MODEL=mistralai/mistral-7b-instruct-v0.3

# HTTP timeout (seconds) for a single chat completion call.
BA_REQUEST_TIMEOUT=180

# Hard-stop if a built prompt would exceed this many estimated tokens. Set
# well below your model's loaded context_length so we never silently truncate.
BA_MAX_PROMPT_TOKENS=3000
