# Copy to .env and adjust.
# LM Studio exposes an OpenAI-compatible server. Default port is 1234.
# Start it from LM Studio -> "Developer" -> "Start Server".

LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Model identifier as it appears in LM Studio's loaded-model list.
# Examples: "llama-3.1-8b-instruct", "qwen2.5-7b-instruct", "mistral-7b-instruct"
BA_MODEL=llama-3.1-8b-instruct

# Generation knobs
BA_TEMPERATURE=0.2
BA_MAX_TOKENS=2048

# Request timeout (seconds) for a single chat completion call
BA_REQUEST_TIMEOUT=120
